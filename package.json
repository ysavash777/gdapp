{
  "name": "gdapp",
  "version": "0.1.0",
  "private": true,
  "description": "GDapp — plataforma WEB (/desk) + PWA (/app) con acceso unificado",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "build:zxing": "esbuild build/zxing-entry.js --bundle --format=esm --platform=browser --minify --outfile=public/shared/js/vendor/zxing.bundle.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@zxing/browser": "^0.2.1",
    "@zxing/library": "^0.23.0",
    "esbuild": "^0.28.1"
  }
}
